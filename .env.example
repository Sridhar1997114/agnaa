# --- pro.agnaa.in Environment Template ---

# 1. Supabase Configuration
# Create a project at https://supabase.com and get these from Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"

# 2. Application Logic
# Set this to true to force a global maintenance mode redirect
NEXT_PUBLIC_MAINTENANCE_MODE="false"

# 3. Development / Debugging
# Set to 'debug' to output extra logs in the console
NEXT_PUBLIC_LOG_LEVEL="info"
